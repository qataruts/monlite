{
  "name": "@monlite/electron",
  "version": "0.1.1",
  "description": "Electron helper for @monlite/core: a main-process database shared with renderer windows over IPC, with cross-window reactivity.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "monlite",
    "electron",
    "ipc",
    "desktop",
    "monlite",
    "multi-window",
    "sqlite"
  ],
  "license": "MIT",
  "author": "Emad Jumaah <emadjumaah@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qataruts/monlite.git",
    "directory": "packages/kv"
  },
  "homepage": "https://github.com/qataruts/monlite/tree/main/packages/kv#readme",
  "bugs": {
    "url": "https://github.com/qataruts/monlite/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@monlite/core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "better-sqlite3": "^11.8.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
