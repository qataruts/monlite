{
  "name": "@monlite/wasm",
  "version": "0.2.1",
  "description": "Run @monlite/core in the browser (or anywhere) on SQLite-WASM via sql.js — a custom driver.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "monlite",
    "wasm",
    "sqlite",
    "browser",
    "sql.js",
    "local-first",
    "opfs"
  ],
  "license": "MIT",
  "author": "Emad Jumaah <emadjumaah@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qataruts/monlite.git",
    "directory": "packages/wasm"
  },
  "homepage": "https://github.com/qataruts/monlite/tree/main/packages/wasm#readme",
  "bugs": {
    "url": "https://github.com/qataruts/monlite/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@monlite/core": "workspace:^"
  },
  "peerDependencies": {
    "sql.js": ">=1.8"
  },
  "peerDependenciesMeta": {
    "sql.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/sql.js": "^1.4.9",
    "sql.js": "^1.14.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
