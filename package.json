{
  "name": "@monlite/core",
  "version": "2.6.2",
  "description": "An embedded document database for TypeScript apps. MongoDB-like API, Prisma-like DX, SQLite under the hood. Zero config, zero migrations, zero server.",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bench": "node bench/bench.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sqlite",
    "mongodb",
    "document-database",
    "nosql",
    "embedded",
    "local-first",
    "prisma",
    "better-sqlite3",
    "json"
  ],
  "license": "MIT",
  "author": "Emad Jumaah <emadjumaah@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qataruts/monlite.git"
  },
  "homepage": "https://github.com/qataruts/monlite#readme",
  "bugs": {
    "url": "https://github.com/qataruts/monlite/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9",
    "better-sqlite3-multiple-ciphers": ">=9"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "better-sqlite3-multiple-ciphers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@seald-io/nedb": "^4.1.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "better-sqlite3": "^11.8.0",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "eslint": "^9.17.0",
    "lowdb": "^7.0.1",
    "prettier": "^3.4.2",
    "sql.js": "^1.14.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "better-sqlite3-multiple-ciphers",
      "esbuild"
    ]
  }
}
